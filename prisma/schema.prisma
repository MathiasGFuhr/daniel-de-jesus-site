// Prisma schema — Plataforma multi-cantor (multi-tenant)
// Cada usuário tem um Site (cantor) e gerencia o próprio conteúdo.
// Postgres (Supabase) em produção e desenvolvimento.

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("owner")
  site         Site?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Site {
  id        String   @id @default(cuid())
  slug      String   @unique
  ownerId   String   @unique
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteSettings     SiteSettings?
  themeSettings    ThemeSettings?
  homeContent      HomeContent?
  spotifySettings  SpotifySettings?
  contactSettings  ContactSettings?
  linkPage         LinkPage?
  advancedSettings AdvancedSettings?
  socialLinks      SocialLink[]
  songs            Song[]
  videos           Video[]
  products         Product[]
  linkButtons      LinkPageButton[]
  contactMessages  ContactMessage[]

  @@index([slug])
}

model SiteSettings {
  id               String   @id @default(cuid())
  siteId           String   @unique
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteName         String
  artistName       String
  artistLabel      String
  description      String
  footerText       String
  aiDisclosureText String
  copyrightText    String
  logoUrl          String
  faviconUrl       String
  isPublished      Boolean  @default(true)
  maintenanceMode  Boolean  @default(false)
  defaultLocale    String   @default("pt-BR")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ThemeSettings {
  id              String   @id @default(cuid())
  siteId          String   @unique
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  primaryColor    String
  secondaryColor  String
  accentColor     String
  backgroundColor String
  cardColor       String
  textColor       String
  mutedTextColor  String
  buttonColor     String
  sidebarColor    String
  headerColor     String
  titleFont       String
  bodyFont        String
  cardRadius      String
  buttonStyle     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model HomeContent {
  id                   String   @id @default(cuid())
  siteId               String   @unique
  site                 Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  eyebrow              String
  title                String
  slogan               String
  description          String
  imageUrl             String
  primaryButtonLabel   String
  primaryButtonUrl     String
  secondaryButtonLabel String
  secondaryButtonUrl   String
  thirdButtonLabel     String
  thirdButtonUrl       String
  // seções (toggles)
  showHero          Boolean @default(true)
  showFeaturedVideo Boolean @default(true)
  showSpotify       Boolean @default(true)
  showOfficialLinks Boolean @default(true)
  showProducts      Boolean @default(true)
  showAbout         Boolean @default(true)
  showContact       Boolean @default(true)
  // bio (página sobre)
  bioShort      String   @default("")
  bioFull       String   @default("")
  aboutImageUrl String   @default("")
  aboutGenre    String   @default("")
  aboutYear     String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  label     String
  handle    String
  url       String
  icon      String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, order])
}

model Song {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title         String
  type          String
  year          String
  releaseDate   String?
  coverUrl      String
  description   String
  spotifyUrl    String?
  youtubeUrl    String?
  deezerUrl     String?
  appleMusicUrl String?
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([siteId, order])
}

model Video {
  id              String   @id @default(cuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title           String
  type            String
  description     String
  youtubeUrl      String
  youtubeEmbedUrl String
  thumbnailUrl    String
  publishedAt     String?
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siteId, order])
}

model SpotifySettings {
  id          String   @id @default(cuid())
  siteId      String   @unique
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title       String
  artist      String
  description String
  embedUrl    String
  externalUrl String
  type        String   @default("EP")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  category    String
  price       String
  imageUrl    String
  url         String
  type        String
  tag         String?
  description String
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([siteId, order])
}

model LinkPage {
  id        String   @id @default(cuid())
  siteId    String   @unique
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  avatarUrl String
  title     String
  subtitle  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LinkPageButton {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  label     String
  subtitle  String?
  url       String
  icon      String
  isActive  Boolean  @default(true)
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, order])
}

model ContactSettings {
  id                  String   @id @default(cuid())
  siteId              String   @unique
  site                Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  email               String
  headline            String
  description         String
  address             String?
  instagram           String?
  affiliateDisclaimer String   @default("")
  contactTypes        String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ContactMessage {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  email       String
  contactType String
  message     String
  status      String   @default("novo")
  createdAt   DateTime @default(now())

  @@index([siteId, status])
}

model AdvancedSettings {
  id                String   @id @default(cuid())
  siteId            String   @unique
  site              Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  ownerName         String
  ownerEmail        String
  googleAnalyticsId String   @default("")
  metaPixelId       String   @default("")
  tiktokPixelId     String   @default("")
  customHeadCode    String   @default("")
  customFooterCode  String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
