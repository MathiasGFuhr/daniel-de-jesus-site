# Postgres (Supabase) — runtime usa o pooler (porta 6543)
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Postgres (Supabase) — conexão direta para migrações (porta 5432)
DIRECT_URL="postgresql://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:5432/postgres"

# Segredo usado para assinar a sessão do admin (use um valor longo e aleatório)
AUTH_SECRET="troque-por-um-valor-longo-e-aleatorio"

# Credenciais do admin usadas no seed inicial
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD="troque-esta-senha"

# Token do Vercel Blob (injetado automaticamente na Vercel ao criar o store)
BLOB_READ_WRITE_TOKEN=""
